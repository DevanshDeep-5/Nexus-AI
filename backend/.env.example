# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Supported providers (see backend/app/services/llm.py):
#   OpenAI:     OPENAI_API_KEY=sk-...
#   OpenRouter: OPENAI_API_KEY=sk-or-v1-...  (or OPENROUTER_API_KEY=sk-or-v1-...)
#               Use a :free model or google/gemini-2.0-flash-lite-001 — not paid models.
#   Gemini:     OPENAI_API_KEY=AIzaSy...

# ── LLM provider ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-api-key-here
# OPENROUTER_API_KEY=sk-or-v1-your-key-here

# OpenRouter — use :free models if you have no credits:
OPENAI_MODEL=meta-llama/llama-3.2-3b-instruct:free
# Paid / credit-based examples:
#   google/gemini-2.0-flash-lite-001

# Paid OpenAI embeddings only — ignored when using OpenRouter (local embeddings instead)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Text processing / RAG ──────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_PAGE_LENGTH=100000
TOP_K_RESULTS=5
